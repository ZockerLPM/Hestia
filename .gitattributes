# Default: konsistente LF line endings im Repo, egal auf welcher Plattform
* text=auto eol=lf

# Linux-spezifische Dateien dürfen nie CRLF haben — sonst:
#   - shebangs schlagen mit "Permission denied" / "no such file or directory" fehl
#   - systemd-Unit-Parser stolpern über \r am Zeilenende
#   - Python wirft SyntaxError bei `# coding: utf-8\r`
*.sh        text eol=lf
*.bash      text eol=lf
*.service   text eol=lf
*.py        text eol=lf
*.conf      text eol=lf
Dockerfile  text eol=lf
*.dockerignore text eol=lf

# Windows-Helper dürfen CRLF behalten
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binärdateien — git soll nicht versuchen, sie zu konvertieren
*.png   binary
*.jpg   binary
*.jpeg  binary
*.ico   binary
*.bin   binary
*.woff  binary
*.woff2 binary
*.pdf   binary
