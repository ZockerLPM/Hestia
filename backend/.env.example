DATABASE_URL="file:./data/hestia.db"
JWT_SECRET="hestia-dev-secret-change-in-production"
PORT=3001
NODE_ENV=development

# Web Push (optional, generieren mit `npm run push:keys`)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hestia@example.com

# Verkehr/Stau (optional). Free Tier 2500 calls/day.
# Schlüssel kostenlos auf https://developer.tomtom.com/ erstellen.
# Ohne Key zeigt der Wand-Modus keine Stau-Daten an.
TOMTOM_API_KEY=

# PIR-Bewegungssensor (optional). Wenn gesetzt, muss das Python-Skript am
# Sensor diesen Wert als Header `x-motion-secret` mitschicken, sonst 403.
# Leer lassen, wenn die Backend-API nur loopback-erreichbar ist.
MOTION_SECRET=

# Home-Assistant-Integration (optional). Wenn beide gesetzt, kann Hestia
# HA-Sensoren auf der Wand anzeigen und Lichter/Heizung/Szenen steuern.
# Token in HA erzeugen: Profil → Sicherheit → Long-Lived Access Tokens.
# URL ohne trailing slash, z.B. http://homeassistant.local:8123
# Ohne Konfiguration bleiben die HA-Karten leer (kein Crash).
HOMEASSISTANT_URL=
HOMEASSISTANT_TOKEN=
